{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MinNote",
  "version": "1.0.0",
  "identifier": "com.seongmin.minnote",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "MinNote",
        "width": 1440,
        "height": 920,
        "minWidth": 450,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ChoSeongmin1128/MinNote/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE5RUE0NDJENUM1QzA1NkUKUldSdUJWeGNMVVRxcVZ2WkxFUm12Y3NLSmhpaXM4eklHUW9aLzh6NmlJSVFWUXBCSnVRenRuRWMK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/minnote-sync"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "minimumSystemVersion": "14.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
