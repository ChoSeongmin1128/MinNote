{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MinNote",
  "version": "1.0.3",
  "identifier": "com.seongmin.minnote",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "MinNote",
        "width": 1180,
        "height": 860,
        "minWidth": 450,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ChoSeongmin1128/MinNote/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBMzkyQTFFOEQ3RUI2RjMKUldUenRuNk5IaW81aXRwbFFTMlVQemV2UWpaaUdmQnNMYmwvVk5XNHUzUU5KeVRJSmxyN3lwNHkK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": [
      "binaries/minnote-sync"
    ],
    "macOS": {
      "dmg": {
        "windowSize": {
          "width": 720,
          "height": 420
        },
        "windowPosition": {
          "x": 240,
          "y": 180
        },
        "appPosition": {
          "x": 190,
          "y": 210
        },
        "applicationFolderPosition": {
          "x": 520,
          "y": 210
        }
      },
      "entitlements": "Entitlements.plist",
      "minimumSystemVersion": "14.0",
      "files": {
        "embedded.provisionprofile": "embedded.provisionprofile"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
